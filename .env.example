# URL del backend SaaS (cuando exista). En desarrollo dejar vacío.
BACKEND_URL=http://localhost:3001

# Si true, las llamadas al backend se interceptan localmente y devuelven datos
# de prueba. Útil para desarrollar la UI sin levantar el backend.
MOCK_BACKEND=false

# Host y puerto de la UI local de zf-vision.
# Por defecto 127.0.0.1:8765 — no exponer a la red sin auth.
HOST=127.0.0.1
PORT=8765

# Nivel de log: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# Intervalo único (segundos) para metric, heartbeat y long-poll de comandos.
PUSH_INTERVAL_S=5
